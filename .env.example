# Local development only. This file is safe to commit because it has no values.
# Use the Supabase project URL and its publishable/anon key. Never use a
# Postgres password, service-role key, or any other privileged secret here.
STEPLI_SUPABASE_URL=https://your-project.supabase.co
STEPLI_SUPABASE_ANON_KEY=your-supabase-publishable-anon-key
# Google OAuth client ID of type "Web application". This ID is public; do
# not put the Google client secret in this file or the app.
STEPLI_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
